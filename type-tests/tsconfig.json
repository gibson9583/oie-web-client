{
  "//": "Type-only regression guard for the @oie/* public API. Run via `npm run typecheck`. No JS is emitted.",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "types": []
  },
  "include": ["*.test-d.ts"]
}
